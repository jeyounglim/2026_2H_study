# 루트 docker-compose 프로덕션용 환경변수 예시
# 사용: cp .env.production.example .env  후 값 수정 (Git에 커밋하지 않음)

# VM 공인 IP 또는 도메인 (예: 123.45.67.89)
PUBLIC_HOST=YOUR_PUBLIC_IP

MYSQL_ROOT_PASSWORD=change-me-strong-password
MYSQL_DATABASE=board_db

JWT_SECRET=change-me-long-random-secret

# 프론트/백엔드 URL (공인 IP 기준)
CLIENT_URL=http://YOUR_PUBLIC_IP:3000
NUXT_PUBLIC_API_BASE=http://YOUR_PUBLIC_IP:4000/api

# SMTP (선택, 미설정 시 콘솔에 인증 링크 출력)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@board.local
