# ===== Database =====
# MySQL 연결 문자열 (형식: mysql://USER:PASSWORD@HOST:PORT/DB_NAME)
DATABASE_URL="mysql://root:password@localhost:3306/board_db"

# ===== Server =====
PORT=4000
# 프론트엔드 주소 (CORS 허용 및 이메일 인증 링크 생성에 사용)
CLIENT_URL="http://localhost:3000"

# ===== Auth =====
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="1d"

# ===== Email (nodemailer / SMTP) =====
# 값이 비어있으면 인증 메일을 실제로 보내지 않고 콘솔에 인증 링크를 출력합니다.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@board.local"
